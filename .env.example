# ── Deep Claw Environment Configuration ──────────────────────────────────────
# Copy to .env and fill in real values. Never commit .env.

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Deriv
DERIV_APP_ID=
DERIV_API_TOKEN=
DERIV_WS_URL=wss://ws.binaryws.com/websockets/v3

# Bybit
BYBIT_API_KEY=
BYBIT_API_SECRET=
BYBIT_TESTNET=false

# MT5 (direct bridge — no TradeSgnl)
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
MT5_PATH=

# Telegram
TG_WARROOM_TOKEN=
TG_WARROOM_CHAT_ID=
TG_PUBLIC_TOKEN=
TG_PUBLIC_CHAT_ID=
TG_PUBLIC_SANITIZE=true

# Risk defaults (override per-symbol in instrument_registry.yaml)
RISK_PER_TRADE_USD=25.0
MAX_EQUITY_RISK_PCT=0.02
CONFIDENCE_THRESHOLD=60.0
USE_ML_CONFIDENCE=false

# Funded account (Atlas/MT5 prop)
FUNDED_DAILY_LOSS_PCT=0.05
FUNDED_MAX_DD_PCT=0.10

# Admin
ADMIN_BIAS=AUTO
OPERATOR_NOTE=
ASSET_CONTEXT=

# Feature flags
ENABLE_VANILLA_SLEEVE=false
ENABLE_CLAUDE_QUALIFICATION=true
ENABLE_TELEGRAM=true
LOG_LEVEL=INFO
