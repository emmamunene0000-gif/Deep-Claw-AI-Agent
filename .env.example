# Deep Claw — environment configuration
# Copy to .env and fill in your values. NEVER commit .env.

# ── Anthropic ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
CLAUDE_MODEL_QUALIFICATION=claude-sonnet-4-6
CLAUDE_MODEL_AUTOPSY=claude-sonnet-4-6
CLAUDE_MODEL_ASSESSMENT=claude-opus-4-8

# ── Deriv ─────────────────────────────────────────────────────────────────────
# DEMO MODE: get a virtual account at app.deriv.com, generate token there.
# Demo tokens look identical to live — different account type only.
DERIV_APP_ID=1089
DERIV_API_TOKEN=your-deriv-demo-token-here
DERIV_WS_URL=wss://ws.binaryws.com/websockets/v3

# ── Bybit ─────────────────────────────────────────────────────────────────────
# DEMO MODE: set BYBIT_TESTNET=true, get testnet keys from testnet.bybit.com
BYBIT_API_KEY=your-bybit-testnet-key
BYBIT_API_SECRET=your-bybit-testnet-secret
BYBIT_TESTNET=true

# ── MT5 (direct bridge — no TradeSgnl) ───────────────────────────────────────
# DEMO MODE: MT5_SERVER = your broker's demo server string
MT5_LOGIN=0
MT5_PASSWORD=your-mt5-demo-password
MT5_SERVER=YourBroker-Demo
MT5_PATH=

# ── Telegram ──────────────────────────────────────────────────────────────────
# Create bots via @BotFather. War room = private. Public = optional sanitized feed.
TG_WARROOM_TOKEN=your-warroom-bot-token
TG_WARROOM_CHAT_ID=-100...
TG_PUBLIC_TOKEN=
TG_PUBLIC_CHAT_ID=
TG_PUBLIC_SANITIZE=true
ENABLE_TELEGRAM=true

# ── Risk ──────────────────────────────────────────────────────────────────────
RISK_PER_TRADE_USD=25.0
MAX_EQUITY_RISK_PCT=0.02
CONFIDENCE_THRESHOLD=60.0

# ── Funded account (Atlas/prop) ───────────────────────────────────────────────
FUNDED_DAILY_LOSS_PCT=0.05
FUNDED_MAX_DD_PCT=0.10

# ── Admin / operator ──────────────────────────────────────────────────────────
ADMIN_BIAS=AUTO
OPERATOR_NOTE=
ASSET_CONTEXT=

# ── Feature flags ─────────────────────────────────────────────────────────────
ENABLE_CLAUDE_QUALIFICATION=true
USE_ML_CONFIDENCE=false      # set true when Phase 2 LightGBM model is trained
ONE_TRADE_PER_SYMBOL=true
ENABLE_TELEGRAM=true

# ── Reporting ─────────────────────────────────────────────────────────────────
REPORT_HOUR_UTC=21
LOG_LEVEL=INFO
