// ══════════════════════════════════════════════════════════════════════════════
// PART 10 — DAILY REPORT SELF-ASSESSMENT FIX
// Replace the static assessment strings in Section 28 (daily report) with
// data-driven versions that reference actual session performance.
// ══════════════════════════════════════════════════════════════════════════════
// FIND in Section 28 the "AGENT SELF-ASSESSMENT" block and replace the
// conditional assessment string builder with f_daily_assessment() below:

f_daily_assessment() =>
    // Count signal types from dpt arrays
    int n        = array.size(dpt_type)
    int ct_count = 0
    int s4_count = 0
    int lo_count = 0
    if n > 0
        for i = 0 to n - 1
            string t = array.get(dpt_type, i)
            if t == "COUNTER"
                ct_count += 1
            else if t == "SYNC4"
                s4_count += 1
            else
                lo_count += 1

    float ct_pct = dpt_total_sigs > 0 ? (float(ct_count) / float(dpt_total_sigs)) * 100 : 0.0

    // Build assessment from real data
    string assess = ""

    if dpt_total_sigs == 0
        assess := "Zero signal session. Environment below threshold or operator silence active. Capital preserved."

    else if pip_pf >= 2.0 and pip_win_rate >= 60.0
        assess := "Strong session · PF " + str.tostring(math.min(pip_pf,99.9),"#.##") +
                  " · WR " + str.tostring(pip_win_rate,"##.#") + "%" +
                  " · " + str.tostring(dpt_total_sigs) + " signals · " +
                  str.tostring(pip_tp1_hits) + "×TP1 " +
                  str.tostring(pip_tp2_hits) + "×TP2 " +
                  str.tostring(pip_tp3_hits) + "×TP3 " +
                  str.tostring(pip_losses)   + "×SL"

    else if pip_pf >= 1.0
        assess := "Positive session · PF " + str.tostring(math.min(pip_pf,99.9),"#.##") +
                  " · Net " + str.tostring(pip_net,"#.#") + " " + pip_unit +
                  " · " + str.tostring(pip_wins) + "W / " + str.tostring(pip_losses) + "L"

    else
        assess := "Difficult session · PF " + str.tostring(math.min(pip_pf,99.9),"#.##") +
                  " · " + str.tostring(pip_losses) + " SL vs " + str.tostring(pip_wins) + " TP" +
                  " · Net " + str.tostring(pip_net,"#.#") + " " + pip_unit

    // Append signal type breakdown
    assess += "\nSignal mix: " + str.tostring(s4_count) + " Sync4 · " +
              str.tostring(lo_count) + " Local · " +
              str.tostring(ct_count) + " Counter-trend"

    // Counter-trend drag flag — only shown when meaningful sample
    if ct_pct > 40.0 and dpt_total_sigs >= 3
        assess += "\nCounter-trend represented " + str.tostring(ct_pct,"##.#") +
                  "% of signals — review if CT drag is impacting net result."

    // Score-outcome correlation from f_avg_score_by_outcome
    string score_corr = f_avg_score_by_outcome()
    if score_corr != ""
        assess += "\n" + score_corr

    // Session score drift
    string momentum = f_score_momentum()
    if momentum != ""
        assess += "\n" + momentum

    assess

// ══════════════════════════════════════════════════════════════════════════════
// USAGE EXAMPLE — WHAT AN ENTRY MESSAGE NOW LOOKS LIKE IN TELEGRAM
// ══════════════════════════════════════════════════════════════════════════════
//
// WAR ROOM — Signal #3 on a real session (after 1 TP1 and 1 SL):
//
//   🟢 LONG · EURUSD 1 · 09:47 UTC
//   ──────────────────────────
//   Signal #3 today · Prior: 1.L[LO]+7→TP1  2.S[CT]−3→SL
//   Exec trail ↑ at 1.08320 · ATR trail: 8.2p · ATR MED (12.1p)
//   D↑ 15↑ 5↑ 1↑ · 4/4 layers · Score +9/15 · LDN · Inside daily range
//   With D trail · Majority alignment (9/15) · ATR MED (12.1p)
//   ──────────────────────────
//   Entry  1.08320    SL 1.08240 (8.0p · $25.00)
//   TP1    1.08400 (+8.0p · 1:1)
//   TP2    1.08440 (+12.0p · 1.5:1)
//   TP3    1.08480 (+16.0p · 2:1)
//   Size   0.3125 lots · ID ATM-20260614-0947-BUY-3
//   ──────────────────────────
//   POC 1.08310 · Buy-liq 1.08580 · Sell-liq 1.08040
//   Score ↑ from −3 at LDN open (now +9 — structural shift)
//   → Full 4-layer alignment long. Trail consensus across all TFs.
//
// The agent is now speaking its own mechanics:
//   — It knows it's on signal #3
//   — It references the prior SL (counter-trend, −3 score) as context
//   — It shows the score shifted from −3 at session open to +9 now
//   — Every line is built from live data, not pre-written phrases
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// WHAT THE DASHBOARD NOW SHOWS (SESSION section, after TODAY block)
// ══════════════════════════════════════════════════════════════════════════════
//
//  ─────────────────────────────
//  📊 SESSION
//  Strong · PF 2.14 · WR 66.7%  · +18.4 pips
//  CT today: 1 signal · TP1 0 · SL 1 [counter-trend drag active]
//  Sync4 today: 2 · TP2+ 2 · SL 0
//  Score ↑ from −3 at LDN open (now +9 — structural shift)
//  Avg score: TP entries 9.2/15 · SL entries 3.0/15
//  ─────────────────────────────
//  📋 EPISODE LOG
//  1.S[CT]−3→SL  2.L[S4]+9→TP2  3.L[S4]+11→TP1  4.L[LO]+7→OPEN
//
// Performance table footer row now shows:
//  [Strong · PF 2.14 · WR 66.7% · +18.4 pips]  [CT: 1 signal · TP1 0 · SL 1]  [© 2026]
// ══════════════════════════════════════════════════════════════════════════════
