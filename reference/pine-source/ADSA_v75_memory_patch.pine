// ══════════════════════════════════════════════════════════════════════════════
// ADSA v7.5 — EPISODIC MEMORY & REAL PERFORMANCE PATCH
// ══════════════════════════════════════════════════════════════════════════════
// Companion to ADSA_v75_string_patch.pine
// Adds session memory, live self-assessment, and real dashboard intelligence.
//
// KEY INSIGHT: V7 already has episodic memory (dpt_* arrays track every signal,
// its type, score, and outcome). The problem is nothing reads them for narrative.
// This patch builds reading functions over the existing arrays and wires them
// into entry commentary and the dashboard — no new data collection needed.
//
// WHAT THIS ADDS:
//   PART 5 — Session memory variables (score at open, score history)
//             Insert before Section 22 (alongside dpt_* declarations, ~line 1920)
//   PART 6 — Memory reading functions
//             Insert before Section 23 (dashboard, ~line 2012)
//   PART 7 — Dashboard additions
//             Patch into Section 23 dashboard string builder (tradeSection area)
//   PART 8 — Memory-enhanced entry commentary
//             Updates to PART 4 in first patch: prepend f_signal_context() to
//             buy/sell entry event_commentary blocks
//
// HOW TO APPLY:
//   STEP 1 — Paste PART 5 after the dpt_* array declarations (~line 1939)
//   STEP 2 — Paste PART 6 before Section 23 (~line 2012)
//   STEP 3 — In Section 23 dashboard, find the "TODAY" block and add PART 7 after it
//   STEP 4 — In PART 4 of the first patch (entry commentary for buy/sell signals),
//             prepend f_signal_context() + "\n" to event_commentary
// ══════════════════════════════════════════════════════════════════════════════

// ══════════════════════════════════════════════════════════════════════════════
// PART 5 — SESSION MEMORY VARIABLES
// Insert after dpt_* declarations (~line 1939), before the _new_trading_day block
// ══════════════════════════════════════════════════════════════════════════════
// These track state that the dpt_* arrays don't already cover:
//   — score at session open (to show drift during session)
//   — session-level signal index (resets each VP session, not each day)
//     Note: dpt_* reset on _new_trading_day. Session resets on vp_newSession.
//     A single day can have multiple VP sessions (London → NY). Session memory
//     tracks context within the current active VP session.

var float  mem_session_open_score = na     // total_score when vp_newSession fired
var string mem_session_open_bias  = ""     // effective_bias at session open
var int    mem_session_sig_count  = 0      // signals fired in THIS VP session (resets each session)
var int    mem_session_sl_count   = 0      // SL hits in THIS VP session
var int    mem_session_tp_count   = 0      // any TP hit in THIS VP session
var int    mem_session_start_bar  = 0      // bar_index when session opened
var string mem_session_label      = ""     // "LDN", "NY", "TKO"

// Reset session memory on each new VP session
if vp_newSession
    mem_session_open_score := total_score
    mem_session_open_bias  := effective_bias
    mem_session_sig_count  := 0
    mem_session_sl_count   := 0
    mem_session_tp_count   := 0
    mem_session_start_bar  := bar_index
    mem_session_label      := str.contains(current_session,"NY")     ? "NY"  :
                               str.contains(current_session,"LONDON") ? "LDN" : "TKO"

// Update session memory on events
if buy_signal_confirmed or sell_signal_confirmed
    mem_session_sig_count := mem_session_sig_count + 1
if sl_alert_event
    mem_session_sl_count  := mem_session_sl_count + 1
if tp1_alert_event or tp2_alert_event or tp3_alert_event
    mem_session_tp_count  := mem_session_tp_count + 1

// ══════════════════════════════════════════════════════════════════════════════
// PART 6 — MEMORY READING FUNCTIONS
// Insert before Section 23 (dashboard, ~line 2012)
// All functions read the existing dpt_* arrays — no new data collection.
// ══════════════════════════════════════════════════════════════════════════════

// ── f_ep_result_str: compact outcome for a single dpt episode ──────────────
// Returns "TP3", "TP2", "TP1", "SL", "OPEN", or "?"
f_ep_result_str(int idx) =>
    bool t1  = array.get(dpt_tp1_hit, idx)
    bool t2  = array.get(dpt_tp2_hit, idx)
    bool t3  = array.get(dpt_tp3_hit, idx)
    bool sl  = array.get(dpt_sl_hit,  idx)
    bool cur = idx == dpt_active_idx and trade_active
    sl ? "SL" : t3 ? "TP3" : t2 ? "TP2" : t1 ? "TP1" : cur ? "OPEN" : "?"

// ── f_session_log: compact episode log from dpt arrays ────────────────────
// Example output: "1.L[S4]+11→TP2  2.S[CT]−3→SL  3.L[LO]+8→OPEN"
// Shows every signal this trading day with direction, type, score, outcome.
f_session_log() =>
    int    n   = array.size(dpt_dir)
    string log = ""
    if n > 0
        for i = 0 to n - 1
            int    d    = array.get(dpt_dir,   i)
            float  sc   = array.get(dpt_score, i)
            string t    = array.get(dpt_type,  i)
            string dir  = d == 1 ? "L" : "S"
            string typ  = t == "SYNC4" ? "S4" : t == "COUNTER" ? "CT" : "LO"
            string sc_s = sc > 0 ? "+" + str.tostring(sc,"#.#") : str.tostring(sc,"#.#")
            string res  = f_ep_result_str(i)
            log += str.tostring(i+1) + "." + dir + "[" + typ + "]" + sc_s + "→" + res + "  "
    n == 0 ? "No signals yet today." : log

// ── f_signal_context: session context for entry commentary ────────────────
// Called at signal time — references dpt arrays BEFORE the new signal is pushed.
// Returns: "Signal #3 this session · Prior: 1.L[S4]+11→TP2  2.S[CT]−3→SL"
f_signal_context() =>
    int n = array.size(dpt_dir)     // count BEFORE this signal is pushed
    if n == 0
        "First signal this session."
    else
        // Show last 2 prior signals max (keep Telegram message lean)
        int    from_idx = math.max(0, n - 2)
        string prior    = ""
        for i = from_idx to n - 1
            int    d   = array.get(dpt_dir,   i)
            float  sc  = array.get(dpt_score, i)
            string t   = array.get(dpt_type,  i)
            string dir = d == 1 ? "L" : "S"
            string typ = t == "SYNC4" ? "S4" : t == "COUNTER" ? "CT" : "LO"
            string sc_s = sc > 0 ? "+" + str.tostring(sc,"#.#") : str.tostring(sc,"#.#")
            string res  = f_ep_result_str(i)
            prior += str.tostring(i+1) + "." + dir + "[" + typ + "]" + sc_s + "→" + res + "  "
        "Signal #" + str.tostring(n+1) + " today · Prior: " + prior

// ── f_score_momentum: how score has drifted since session open ─────────────
// Returns "" if no session open recorded yet.
// Example: "Score ↑ from −4 at LDN open (now +8 — structural shift)"
f_score_momentum() =>
    if na(mem_session_open_score)
        ""
    else
        float drift = total_score - mem_session_open_score
        string arrow = drift > 2 ? "↑" : drift < -2 ? "↓" : "→"
        string mag   = math.abs(drift) > 6 ? " — structural shift" :
                       math.abs(drift) > 3 ? " — bias strengthening" : ""
        "Score " + arrow + " from " + str.tostring(mem_session_open_score,"#.#") +
        " at " + mem_session_label + " open (now " +
        str.tostring(total_score,"#.#") + mag + ")"

// ── f_ct_summary: counter-trend signal performance from dpt arrays ─────────
// Reads all signals tagged "COUNTER" and reports their outcomes honestly.
f_ct_summary() =>
    int n        = array.size(dpt_type)
    int ct_total = 0
    int ct_tp1   = 0
    int ct_tp2   = 0
    int ct_sl    = 0
    if n > 0
        for i = 0 to n - 1
            if array.get(dpt_type, i) == "COUNTER"
                ct_total += 1
                if array.get(dpt_tp1_hit, i)
                    ct_tp1 += 1
                if array.get(dpt_tp2_hit, i)
                    ct_tp2 += 1
                if array.get(dpt_sl_hit, i)
                    ct_sl += 1
    ct_total == 0 ? "" :
    "CT today: " + str.tostring(ct_total) + " signal" + (ct_total > 1 ? "s" : "") +
    " · TP1 " + str.tostring(ct_tp1) + " · TP2 " + str.tostring(ct_tp2) +
    " · SL " + str.tostring(ct_sl) +
    (ct_sl > ct_tp1 and ct_total >= 2 ? " [counter-trend drag active]" : "")

// ── f_sync4_summary: master sync signal performance ───────────────────────
f_sync4_summary() =>
    int n          = array.size(dpt_type)
    int s4_total   = 0
    int s4_tp2plus = 0
    int s4_sl      = 0
    if n > 0
        for i = 0 to n - 1
            if array.get(dpt_type, i) == "SYNC4"
                s4_total += 1
                if array.get(dpt_tp2_hit, i) or array.get(dpt_tp3_hit, i)
                    s4_tp2plus += 1
                if array.get(dpt_sl_hit, i)
                    s4_sl += 1
    s4_total == 0 ? "" :
    "Sync4 today: " + str.tostring(s4_total) + " · TP2+ " + str.tostring(s4_tp2plus) +
    " · SL " + str.tostring(s4_sl)

// ── f_live_assessment: real-time session self-assessment ──────────────────
// Replaces the static "HIGH QUALITY SESSION" / "AVERAGE SESSION" strings.
// Built entirely from live pip tracker data — updates every bar.
f_live_assessment() =>
    if dpt_total_sigs == 0
        "No signals this session yet."
    else
        // Core quality read
        string quality = pip_pf >= 2.0 and pip_win_rate >= 60.0 ?
             "Strong · PF " + str.tostring(math.min(pip_pf,99.9),"#.##") +
             " · WR " + str.tostring(pip_win_rate,"##.#") + "%" :
             pip_pf >= 1.5 ?
             "Good · PF "  + str.tostring(math.min(pip_pf,99.9),"#.##") +
             " · WR " + str.tostring(pip_win_rate,"##.#") + "%" :
             pip_pf >= 1.0 ?
             "Positive · PF " + str.tostring(math.min(pip_pf,99.9),"#.##") :
             pip_losses > 0 and pip_wins == 0 ?
             "Difficult · 0 TP vs " + str.tostring(pip_losses) + " SL" :
             "Mixed · " + str.tostring(pip_wins) + "W / " + str.tostring(pip_losses) + "L"

        // Net pips
        string net_s = pip_net > 0 ?
             " · +" + str.tostring(pip_net,"#.#") + " " + pip_unit :
             pip_net < 0 ?
             " · "  + str.tostring(pip_net,"#.#") + " " + pip_unit : ""

        // Signal volume note
        string vol_s = dpt_total_sigs >= 5 ? " · High signal count (" +
             str.tostring(dpt_total_sigs) + ")" : ""

        quality + net_s + vol_s

// ── f_avg_score_by_outcome: avg entry score for TP hits vs SL hits ─────────
// Shows whether higher-score signals are actually delivering better outcomes.
f_avg_score_by_outcome() =>
    int   n        = array.size(dpt_dir)
    float tp_score = 0.0
    float sl_score = 0.0
    int   tp_n     = 0
    int   sl_n     = 0
    if n > 0
        for i = 0 to n - 1
            float sc = array.get(dpt_score, i)
            bool  tp = array.get(dpt_tp1_hit, i)
            bool  sl = array.get(dpt_sl_hit,  i)
            if tp
                tp_score += math.abs(sc)
                tp_n     += 1
            if sl
                sl_score += math.abs(sc)
                sl_n     += 1
    if tp_n == 0 and sl_n == 0
        ""
    else
        string tp_avg = tp_n > 0 ? str.tostring(tp_score / tp_n,"#.#") : "—"
        string sl_avg = sl_n > 0 ? str.tostring(sl_score / sl_n,"#.#") : "—"
        "Avg score: TP entries " + tp_avg + "/15 · SL entries " + sl_avg + "/15"

// ══════════════════════════════════════════════════════════════════════════════
// PART 7 — DASHBOARD ADDITIONS
// Patch into Section 23 (main dashboard, ~line 2013 area)
// Find the "TODAY" block in the dashboard table.cell() calls and add these
// table.cell() calls AFTER the existing TODAY rows.
// The dashboard currently ends at row ~14. Add rows 15, 16, 17.
// ══════════════════════════════════════════════════════════════════════════════
// Note on table structure: V7 dashboard uses a single-column table where each
// row is built by concatenating strings into one wide cell. The additions below
// follow the same pattern — they extend the dashboard text, not add new columns.

// ── ADDITION TO DASHBOARD STRING (insert after the "TODAY" section) ─────────
// In Section 23, find where the dashboard text is assembled and append these
// blocks after the existing Sigs/WR/Report lines:

// Block A — Live Assessment (replaces static assessment in daily report section)
// Append to dashText string after the TODAY data:

string dash_assessment_block =
     " ─────────────────────────────\n" +
     " 📊 SESSION\n" +
     " " + f_live_assessment() + "\n" +
     (f_ct_summary() != "" ? " " + f_ct_summary() + "\n" : "") +
     (f_sync4_summary() != "" ? " " + f_sync4_summary() + "\n" : "") +
     (f_score_momentum() != "" ? " " + f_score_momentum() + "\n" : "") +
     (f_avg_score_by_outcome() != "" ? " " + f_avg_score_by_outcome() + "\n" : "")

// Block B — Episode Log (compact signal history)
// Shows every signal today with type, score, and outcome in one line
string dash_episode_log =
     " ─────────────────────────────\n" +
     " 📋 EPISODE LOG\n" +
     " " + f_session_log() + "\n"

// ── HOW TO INSERT: ──────────────────────────────────────────────────────────
